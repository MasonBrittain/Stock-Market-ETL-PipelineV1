# ── Tickers ──────────────────────────────────────────────────────────────────
# Comma-separated Yahoo Finance ticker symbols
TICKERS=AAPL,MSFT,NVDA,GOOGL,AMZN

# ── Data Window ───────────────────────────────────────────────────────────────
# Data interval: 1d (daily), 1h (hourly), etc.
INTERVAL=1d

# Calendar days to look back for tickers that have no stored data yet.
# On subsequent runs, the pipeline downloads only from the last stored date.
LOOKBACK_DAYS=730

# ── Database ──────────────────────────────────────────────────────────────────
# SQLAlchemy connection URL. Defaults to a local SQLite file.
# For PostgreSQL: postgresql+psycopg2://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///data/stock_market.db

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=logs
REPORTS_DIR=reports
